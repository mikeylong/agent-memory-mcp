{
  "name": "agent-memory-mcp",
  "version": "0.2.0",
  "description": "Local cross-agent memory layer over MCP",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "agent-memory-mcp": "dist/index.js",
    "agent-memory-wrapper": "dist/wrapper.js",
    "agent-memory-import-codex": "dist/importCodexSession.js",
    "agent-memory-import-claude": "dist/importClaudeSession.js",
    "agent-memory-import-chatgpt": "dist/importChatgptExport.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikeylong/agent-memory-mcp.git"
  },
  "homepage": "https://github.com/mikeylong/agent-memory-mcp#readme",
  "bugs": {
    "url": "https://github.com/mikeylong/agent-memory-mcp/issues"
  },
  "keywords": [
    "mcp",
    "memory",
    "sqlite",
    "codex",
    "claude"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/db && cp -R src/db/schema dist/db/",
    "dev": "tsx src/index.ts",
    "privacy:scan": "bash scripts/privacy-scan.sh",
    "install:clients": "bash scripts/install-clients.sh",
    "release:check": "bash scripts/release-check.sh",
    "wrapper": "tsx src/wrapper.ts",
    "import:codex-session": "tsx src/importCodexSession.ts",
    "import:claude-session": "tsx src/importClaudeSession.ts",
    "import:codex:latest": "bash scripts/import-codex-session.sh",
    "import:claude:latest": "bash scripts/import-claude-session.sh",
    "enable:claude-wrapper": "bash scripts/enable-claude-wrapper.sh",
    "import:chatgpt-export": "tsx src/importChatgptExport.ts",
    "wrapper:codex": "tsx src/wrapper.ts --codex",
    "wrapper:claude": "tsx src/wrapper.ts --claude",
    "automation:bootstrap": "tsx src/automationBootstrap.ts",
    "automation:health-drift": "tsx src/automationHealthDrift.ts",
    "automation:import-sync": "tsx src/automationImportSync.ts",
    "automation:retrieval-qa": "tsx src/automationRetrievalQa.ts",
    "automation:cleanup": "tsx src/automationSelectiveCleanup.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "better-sqlite3": "^11.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
